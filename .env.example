DATABASE_URL=postgres://localhost/travel_tw
# Server-only. Used by Places / Directions API calls. Restrict to IP (or keep unrestricted for local dev).
GOOGLE_MAPS_API_KEY=
# Client-exposed (bundled into JS). Used by the interactive map (@vis.gl/react-google-maps). Restrict to HTTP referrer in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Map ID for Advanced Markers / Cloud-based styling. Required for event & lodging pins to render.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
# Server-only. Used by the stay-duration AI chat (Gemini). Do not expose to the client.
GEMINI_API_KEY=
